<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Register CAD Part">
  <BehaviorTree
    ID="Register CAD Part"
    _description="Load an STL from disk and use registration to align the pointcloud with a matching shape in the environment"
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action ID="ClearSnapshot" />
      <SubTree ID="Look at Table" _collapsed="true" />
      <Action
        ID="CreatePoseStamped"
        reference_frame="world"
        position_xyz="-1.0;.5;0.7"
        orientation_xyzw="0;0;0;1"
        pose_stamped="{pose_stamped}"
        name="Initial Guess"
      />
      <Action
        ID="LoadPointCloudFromFile"
        name="Load the microscope model as the red before cloud"
        color="255;0;0"
        package_name="lab_sim"
        file_path="description/assets/microscope.stl"
        point_cloud="{red_cloud}"
      />
      <Action
        ID="TransformPointCloudFrame"
        name="Transform the red model cloud into the world frame"
        input_cloud="{red_cloud}"
        output_cloud="{red_cloud}"
      />
      <Action
        ID="TransformPointCloud"
        input_cloud="{red_cloud}"
        transform_pose="{pose_stamped}"
        output_cloud="{red_cloud}"
        name="Place the red model cloud at the initial guess"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{red_cloud}" />
      <SubTree
        ID="Move to Waypoint"
        _collapsed="true"
        waypoint_name="Look at Microscope"
      />
      <Action
        ID="GetPointCloud"
        message_out="{wrist_point_cloud}"
        message_timeout_sec="10.0"
        publisher_timeout_sec="10.0"
      />
      <Action
        ID="TransformPointCloudFrame"
        name="Transform the live wrist cloud into the world frame"
        input_cloud="{wrist_point_cloud}"
        output_cloud="{wrist_point_cloud}"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{wrist_point_cloud}" />
      <Action
        ID="RegisterPointClouds"
        name="Compute the ICP correction relative to the initial guess"
        target_point_cloud="{wrist_point_cloud}"
        base_point_cloud="{red_cloud}"
        max_correspondence_distance="0.5"
        max_iterations="100"
        target_pose_in_base_frame="{target_pose}"
      />
      <Action
        ID="LoadPointCloudFromFile"
        name="Load the microscope model as the green after cloud"
        color="0;255;0"
        package_name="lab_sim"
        file_path="description/assets/microscope.stl"
        point_cloud="{green_cloud}"
      />
      <Action
        ID="TransformPointCloudFrame"
        name="Transform the green model cloud into the world frame"
        input_cloud="{green_cloud}"
        output_cloud="{green_cloud}"
      />
      <Action
        ID="TransformPointCloud"
        input_cloud="{green_cloud}"
        transform_pose="{pose_stamped}"
        output_cloud="{green_cloud}"
        name="Place the green model cloud at the initial guess"
      />
      <Action
        ID="TransformPointCloud"
        input_cloud="{green_cloud}"
        transform_pose="{target_pose}"
        output_cloud="{output_cloud_aligned}"
        name="Apply the ICP correction on top of the initial guess"
      />
      <Action ID="SendPointCloudToUI" point_cloud="{output_cloud_aligned}" />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Register CAD Part">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Perception - 3D Point Cloud" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
