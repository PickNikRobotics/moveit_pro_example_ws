<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Place Object">
  <BehaviorTree
    ID="Place Object"
    _description="Place an object in the gripper at a manually specified location"
    _favorite="false"
  >
    <Control ID="Sequence" name="root">
      <Control ID="Sequence">
        <Action ID="SwitchUIPrimaryView" primary_view_name="Visualization" />
        <Action
          ID="CreatePoseStamped"
          orientation_xyzw="0;1;0;0"
          position_xyz="-0.15905; 0.51283; 0.55"
          pose_stamped="{pose_stamped}"
          reference_frame="world"
        />
        <Action ID="ResetVector" vector="{place_poses}" />
        <Action
          ID="PushBackVector"
          input_vector="{place_poses}"
          element="{pose_stamped}"
          output_vector="{place_poses}"
        />
      </Control>
      <SubTree
        ID="Place at Pose with Approval"
        _collapsed="true"
        place_poses="{place_poses}"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Place Object">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Manipulation" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
