<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="MPC Pose Tracking">
  <!--//////////-->
  <BehaviorTree
    ID="MPC Pose Tracking"
    _description="Uses Model Predictive Control (MPC) to track a target that sweeps along a straight line while rotating."
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Control ID="Sequence">
        <SubTree
          ID="Move to Waypoint"
          _collapsed="true"
          joint_group_name="manipulator"
          waypoint_name="Pose Tracking"
        />
        <Action
          ID="CreatePoseStamped"
          reference_frame="pinch"
          pose_stamped="{orient_carrier}"
          position_xyz="0;0;0"
          orientation_xyzw="0;0;0;1"
        />
        <Action
          ID="TransformPoseFrame"
          input_pose="{orient_carrier}"
          output_pose="{orient_carrier}"
          target_frame_id="world"
        />
        <Action
          ID="CreatePoseStamped"
          reference_frame="world"
          pose_stamped="{pos_carrier}"
          position_xyz="-0.08;-0.04;0.0"
          orientation_xyzw="0;0;0;1"
        />
        <Action
          ID="TransformPoseWithPose"
          input_pose="{orient_carrier}"
          output_pose="{pose_stamped}"
          transform_pose="{pos_carrier}"
        />
        <Action
          ID="CreateTwistStamped"
          reference_frame="world"
          twist_stamped="{twist_stamped}"
          linear_velocity_xyz="-0.0901;-0.0424;0.0"
          angular_velocity_xyz="0;0;-0.0954"
        />
        <Decorator ID="Delay" delay_msec="100">
          <Decorator ID="ForceSuccess">
            <Decorator ID="Timeout" msec="15000">
              <Control ID="Parallel" success_count="2">
                <Decorator ID="KeepRunningUntilFailure">
                  <Decorator ID="Delay" delay_msec="10">
                    <Control ID="Sequence">
                      <Action
                        ID="TransformPose"
                        input_pose="{pos_carrier}"
                        output_pose="{pos_carrier}"
                        translation_xyz="-0.0017;-0.0008;0.0"
                      />
                      <Action
                        ID="TransformPose"
                        input_pose="{orient_carrier}"
                        output_pose="{orient_carrier}"
                        quaternion_xyzw="0;0;0.0009;1"
                      />
                      <Action
                        ID="TransformPoseWithPose"
                        input_pose="{orient_carrier}"
                        output_pose="{pose_stamped}"
                        transform_pose="{pos_carrier}"
                      />
                    </Control>
                  </Decorator>
                </Decorator>
                <Decorator ID="KeepRunningUntilFailure">
                  <Decorator ID="Delay" delay_msec="100">
                    <Control ID="Sequence">
                      <Action
                        ID="VisualizePose"
                        marker_lifetime="0.000000"
                        marker_name="target"
                        marker_size="0.100000"
                        pose="{pose_stamped}"
                      />
                      <Action
                        ID="CreatePoseStamped"
                        reference_frame="pinch"
                        pose_stamped="{current_pinch}"
                      />
                      <Action
                        ID="TransformPoseFrame"
                        input_pose="{current_pinch}"
                        output_pose="{current_pinch}"
                        target_frame_id="world"
                      />
                      <Action
                        ID="VisualizePose"
                        marker_lifetime="0.000000"
                        marker_name="current_pinch"
                        marker_size="0.07"
                        pose="{current_pinch}"
                      />
                    </Control>
                  </Decorator>
                </Decorator>
                <Action
                  ID="SwitchController"
                  activate_controllers="joint_trajectory_controller"
                />
                <Action
                  ID="MPCPoseTracking"
                  horizon="0.2;"
                  timestep="0.010000;"
                  gradient_num_trajectory="32.000000;"
                  gradient_spline_points="1.000000;"
                  planning_group="manipulator"
                  sampling_control_width="0.015000;"
                  sampling_exploration="0.050000;"
                  sampling_sample_width="0.010000;"
                  sampling_spline_points="10.000000;"
                  timeout="300.000000"
                  mujoco_model="description/simple_scene.xml"
                  mujoco_model_package="lab_sim"
                  gripper_site_name="pinch"
                  total_return="{total_return}"
                  differentiable="0"
                  max_cartesian_velocity_goal="0.5"
                  cartesian_velocity_body="tool_changer"
                  max_cartesian_acceleration_goal="500.000000"
                  cartesian_acceleration_body="tool_changer"
                  warmup_iterations="64"
                  max_velocity_goal="0.000000"
                  acceleration="0"
                  cartesian_acceleration="100.000000"
                  cartesian_velocity="100.000000"
                  force_torque="0.000000"
                  site_tracking="1.000000"
                  velocity="0.000000"
                  follow_joint_trajectory_topic="/joint_trajectory_controller/follow_joint_trajectory"
                  set_ctrl_command_to_current_state="true"
                  target_pose="{pose_stamped}"
                  target_twist="{twist_stamped}"
                />
              </Control>
            </Decorator>
          </Decorator>
        </Decorator>
      </Control>
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="MPC Pose Tracking">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Application - MPC Examples" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
