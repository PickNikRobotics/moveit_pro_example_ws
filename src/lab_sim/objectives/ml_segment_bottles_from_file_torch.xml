<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="ML Segment Bottles from File (Torch)">
  <BehaviorTree
    ID="ML Segment Bottles from File (Torch)"
    _description="Loads image of lab from file and uses SAM3 via libtorch (TorchScript) to find bottles. PoC twin of 'ML Segment Bottles from File' for GPUs without a no-compilation ONNX Runtime execution provider (e.g. AMD iGPUs via ROCm)."
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="LoadImageFromFile"
        file_path="objectives/real_lab1.png"
        package_name="lab_sim"
      />
      <Action
        ID="GetMasks2DFromExemplarTorch"
        model_package="moveit_pro_sam3"
        encoder_model_path="models/sam3_vision_encoder.pt"
        decoder_model_path="models/sam3_decoder.pt"
        geometry_encoder_model_path="models/sam3_geometry_encoder.pt"
        text_encoder_model_path="models/sam3_text_encoder.pt"
        confidence_threshold="0.5"
        confidence_scores_str="{confidence_scores_str}"
        target_image="{image}"
        text_prompt="bottles"
        mask_count="{mask_count}"
        masks2d="{masks2d}"
      />
      <Action
        ID="PublishMask2D"
        bounding_box_labels="{confidence_scores_str}"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="ML Segment Bottles from File (Torch)">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Application - ML (GPU Recommended)" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
