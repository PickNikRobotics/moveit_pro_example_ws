<?xml version='1.0' encoding='UTF-8'?>
<root BTCPP_format="4" main_tree_to_execute="Pick All Pill Bottles">
  <BehaviorTree ID="Pick All Pill Bottles" _description="Uses ML vision to detect pill bottles on the workspace, pick them up one at a time, and place them into a tray. Placement poses are loaded from pill_bottle_place_poses.yaml. Each bottle is retried up to 10 times if a pick attempt fails." _favorite="true">
    <Control ID="Sequence" name="TopLevelSequence" _collapsed="false">
      <!--Switch UI to show ML segmentation results-->
      <Action ID="SwitchUIPrimaryView" primary_view_name="/masks_visualization"/>
      <!--Load tray placement poses from pill_bottle_place_poses.yaml. Each pose is a tray slot where a bottle will be placed.-->
      <Action ID="ResetPoseStampedVector" vector="{bottle_place_poses}" name="Initialize placement vector"/>
      <Action ID="LoadPoseStampedVectorFromYaml" output="{bottle_place_poses}" file_path="pill_bottle_place_poses.yaml" name="Load placement poses"/>
      <!--Count total tray slots for progress logging-->
      <Action ID="GetSizeOfVector" vector_in="{bottle_place_poses}" vector_size="{total_bottles}"/>
      <!--Pick and place one bottle per tray slot-->
      <Decorator ID="ForEach" index="{index}" out="{current_bottle_place_pose}" vector_in="{bottle_place_poses}" name="Try to place at each location">
        <Control ID="Sequence" _collapsed="false">
          <!--Reset attempt counter for this bottle-->
          <Action ID="Script" code="attempt_count := 0"/>
          <!--If all 10 retries fail, skip this slot instead of aborting the objective-->
          <Decorator ID="ForceSuccess">
            <!--Retry up to 10 times to pick and place one bottle-->
            <Decorator ID="RetryUntilSuccessful" num_attempts="10">
              <Control ID="Sequence" name="TopLevelSequence" _collapsed="false">
                <!--Log attempt number-->
                <Action ID="Script" code="attempt_count := attempt_count + 1; attempt_msg := 'Bottle ' .. index .. ': attempt ' .. attempt_count .. ' of 10'"/>
                <Action ID="LogMessage" message="{attempt_msg}" log_level="info"/>
                <Action ID="ClearSnapshot"/>
                <SubTree ID="Open Gripper" _collapsed="false"/>
                <!--Visualize the target tray slot-->
                <Action ID="VisualizePose" marker_lifetime="0.000000" marker_name="bottle_drop_pose" marker_size="0.100000" pose="{current_bottle_place_pose}" name="Show drop pose"/>
                <!--Move home for a good camera view-->
                <SubTree ID="Move to Waypoint" _collapsed="false" joint_group_name="manipulator" waypoint_name="Look at Table from Side" name="Look at pill bottles" controller_action_server="/joint_trajectory_admittance_controller/follow_joint_trajectory"/>
                <!--Detect a pill bottle and compute a grasp pose-->
                <SubTree ID="Get Grasp from Text Prompt Subtree" _collapsed="false" camera_image_topic="/wrist_camera/color" camera_info_topic="/wrist_camera/camera_info" camera_points_topic="/wrist_camera/points" planning_group="manipulator" output_grasp="{output_grasp}" mask_threshold=".15" mask_erosion="15" name="Get grasp pose for a pill bottle" object_prompt="colored bottle"/>
                <!--Add table collision object for motion planning-->
                <SubTree ID="Add Table to Planning Scene" _collapsed="false" _skipIf="true"/>
                <!--Pick: approach, grasp, retract-->
                <SubTree ID="Pick from Pose" _collapsed="false" approach_distance="0.1" retract_xyz="0;0;-0.1" grasp_pose="{output_grasp}" suppress_failure_message="true" name="Pick up pill bottle"/>
                <!--Move to predrop position-->
                <SubTree ID="Move to Waypoint" _collapsed="false" joint_group_name="manipulator" waypoint_name="Predrop Bottles Right" name="Move to predrop location"/>
                <!--Place bottle in tray slot-->
                <SubTree ID="Place at Pose" _collapsed="false" approach_distance="0.1" retract_xyz="0;0;-0.1" place_pose="{current_bottle_place_pose}" name="Place pill bottle on table"/>
                <!--Clean up planning scene for next iteration-->
                <SubTree ID="Reset Planning Scene" _collapsed="false"/>
              </Control>
            </Decorator>
          </Decorator>
        </Control>
      </Decorator>
      <!--All tray slots processed-->
      <Action ID="Script" code="done_msg := 'Successfully completed picking ' .. total_bottles .. ' bottle(s)'"/>
      <Action ID="LogMessage" message="{done_msg}" log_level="info"/>
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    
  </TreeNodesModel>
</root>
