<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Get Bottle Grasp via ICP Subtree">
  <BehaviorTree
    ID="Get Bottle Grasp via ICP Subtree"
    _description="Segment a bottle with SAM3, derive an ICP initial guess from the mask centroid, and fit the bottle STL via ICP to produce a grasp pose."
    _favorite="false"
  >
    <Control ID="Sequence">
      <SubTree
        ID="Segment Bottle Subtree"
        name="Segment bottle with SAM3"
        _collapsed="true"
        camera_image_topic="{camera_image_topic}"
        camera_info_topic="{camera_info_topic}"
        camera_points_topic="{camera_points_topic}"
        object_prompt="{object_prompt}"
        exemplar_image="{exemplar_image}"
        target_bboxes="{target_bboxes}"
        exemplar_bboxes="{exemplar_bboxes}"
        masked_cloud_world="{masked_cloud_world}"
      />
      <Action
        ID="GetCentroidFromPointCloud"
        name="Compute ICP initial guess from mask centroid"
        point_cloud="{masked_cloud_world}"
        output_pose="{initial_guess_pose}"
      />
      <SubTree
        ID="Fit Bottle Model Subtree"
        name="Fit bottle STL via ICP"
        _collapsed="true"
        masked_cloud_world="{masked_cloud_world}"
        initial_guess_pose="{initial_guess_pose}"
        grasp_pose="{output_grasp}"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Get Bottle Grasp via ICP Subtree">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Perception - ML" />
      </MetadataFields>
      <inout_port name="camera_image_topic" default="{camera_image_topic}" />
      <inout_port name="camera_info_topic" default="{camera_info_topic}" />
      <inout_port name="camera_points_topic" default="{camera_points_topic}" />
      <inout_port name="object_prompt" default="{object_prompt}" />
      <inout_port name="exemplar_image" default="{exemplar_image}" />
      <inout_port name="target_bboxes" default="{target_bboxes}" />
      <inout_port name="exemplar_bboxes" default="{exemplar_bboxes}" />
      <inout_port name="output_grasp" default="{output_grasp}" />
    </SubTree>
  </TreeNodesModel>
</root>
