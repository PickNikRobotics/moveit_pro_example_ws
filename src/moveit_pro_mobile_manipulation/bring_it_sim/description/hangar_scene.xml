  <option integrator="implicit" timestep="0.005" />
  <visual>
    <headlight diffuse="1.0 1.0 1.0" ambient="0.4 0.4 0.4" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
