<?xml version="1.0" encoding="utf-8" ?>
<root BTCPP_format="4" main_tree_to_execute="run_clipseg">
  <!--//////////-->
  <BehaviorTree ID="run_clipseg">
    <Control ID="Sequence">
      <Action
        ID="GetImage"
        timeout_sec="5.000000"
        topic_name="/wrist_camera/color"
        message_out="{image}"
      />
      <Action
        ID="GetMasks2DFromTextQuery"
        image="{image}"
        masks2d="{masks2d}"
        threshold="0.1"
        clipseg_model_path="models/clipseg.onnx"
        clip_model_path="models/clip.onnx"
        model_package="lab_sim"
        erosion_size="10"
        negative_prompt="wheel gray cart;floor"
        prompt="box;small boxes"
        prompts="{prompts}"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="run_clipseg">
      <MetadataFields>
        <Metadata runnable="true" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
