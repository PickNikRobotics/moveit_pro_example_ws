<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Raster Path Along Fuselage">
  <!--//////////-->
  <BehaviorTree
    ID="Raster Path Along Fuselage"
    _description="Build a 2D raster coverage path over a rectangular region of the airplane fuselage by trimming the wrist-camera point cloud to four corner waypoints, slicing it into evenly spaced contours, and stitching the contours into a boustrophedon Cartesian path."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <SubTree
        ID="Move to Waypoint (JTC)"
        _collapsed="true"
        acceleration_scale_factor="1.0"
        controller_names="joint_trajectory_controller"
        joint_group_name="manipulator"
        keep_orientation="false"
        keep_orientation_tolerance="0.05"
        link_padding="0.0"
        seed="0"
        velocity_scale_factor="1.0"
        waypoint_name="Look at Plane"
      />
      <!--Reset the working vectors used below-->
      <Action ID="ResetPoseStampedVector" vector="{corner_waypoints}" />
      <Action ID="ResetPoseStampedVector" vector="{boustrophedon_path}" />
      <Action ID="Script" code="reverse_flag := 1" />
      <!--Define the four corner waypoints that bound the surface region to cover.
           Corners are exposed as Objective ports so the region can be tuned without editing the XML.-->
      <Action
        ID="CreatePoseStamped"
        reference_frame="world"
        pose_stamped="{corner_bl}"
        position_xyz="{bottom_left_position_xyz}"
        orientation_xyzw="0;0;0;1"
      />
      <Action
        ID="AddPoseStampedToVector"
        input="{corner_bl}"
        vector="{corner_waypoints}"
      />
      <Action
        ID="CreatePoseStamped"
        reference_frame="world"
        pose_stamped="{corner_br}"
        position_xyz="{bottom_right_position_xyz}"
        orientation_xyzw="0;0;0;1"
      />
      <Action
        ID="AddPoseStampedToVector"
        input="{corner_br}"
        vector="{corner_waypoints}"
      />
      <Action
        ID="CreatePoseStamped"
        reference_frame="world"
        pose_stamped="{corner_tr}"
        position_xyz="{top_right_position_xyz}"
        orientation_xyzw="0;0;0;1"
      />
      <Action
        ID="AddPoseStampedToVector"
        input="{corner_tr}"
        vector="{corner_waypoints}"
      />
      <Action
        ID="CreatePoseStamped"
        reference_frame="world"
        pose_stamped="{corner_tl}"
        position_xyz="{top_left_position_xyz}"
        orientation_xyzw="0;0;0;1"
      />
      <Action
        ID="AddPoseStampedToVector"
        input="{corner_tl}"
        vector="{corner_waypoints}"
      />
      <Action
        ID="VisualizePath"
        marker_lifetime="0.000000"
        marker_name="corners"
        path="{corner_waypoints}"
        pose_marker_size="0.100000"
        show_poses="true"
      />
      <!--Capture a point cloud from the wrist camera and lift it into the world frame.-->
      <Action
        ID="GetPointCloud"
        topic_name="/wrist_camera/points"
        message_out="{point_cloud}"
        publisher_timeout_sec="5.000000"
        message_timeout_sec="5.000000"
      />
      <Action
        ID="TransformPointCloudFrame"
        input_cloud="{point_cloud}"
        output_cloud="{point_cloud}"
        target_frame="world"
      />
      <!--Trim the cloud to the quadrilateral defined by the four corner waypoints
           so the slice planes only see fuselage points.-->
      <Action
        ID="TrimPointcloudSurface"
        waypoints="{corner_waypoints}"
        point_cloud="{point_cloud}"
        trimmed_point_cloud="{trimmed_point_cloud}"
      />
      <Action
        ID="SendPointCloudToUI"
        pcd_topic="/pcd_pointcloud_captures"
        point_cloud="{trimmed_point_cloud}"
      />
      <!--Generate evenly spaced slice planes along one edge of the trimmed surface.
           edge_number selects which of the 4 edges the slices run along.-->
      <Action
        ID="FindSlicePlanesAlongEdge"
        waypoints="{corner_waypoints}"
        edge_number="{slice_edge_number}"
        stride_spacing="{stride_spacing}"
        shift_distance="0;0;0"
        output_waypoints="{slice_waypoints}"
      />
      <!--For each slice plane, extract the surface contour at that slice and append it
           to the overall raster path, reversing every other contour to produce a
           boustrophedon (lawn-mower) traversal.-->
      <Decorator
        ID="ForEach"
        index="{slice_index}"
        out="{slice_pose}"
        vector_in="{slice_waypoints}"
      >
        <Control ID="Sequence">
          <Action ID="ResetPoseStampedVector" vector="{contour_path}" />
          <Action
            ID="GetContourFromPointCloudSlice"
            input_cloud="{trimmed_point_cloud}"
            slice_plane="{slice_pose}"
            slice_distance_from_plane="{slice_distance_from_plane}"
            contour_crop_angle_start="{contour_crop_angle_start}"
            contour_crop_angle_span="{contour_crop_angle_span}"
            hull_alpha="{hull_alpha}"
            max_pose_spacing="{max_pose_spacing}"
            contour_path="{contour_path}"
          />
          <Action
            ID="AddOverageToPath"
            waypoints="{contour_path}"
            overage_distance="{overage_distance}"
            num_waypoints="3"
            axis="y"
            output_waypoints="{contour_path_with_overage}"
          />
          <Control ID="Fallback">
            <Decorator ID="Precondition" else="FAILURE" if="reverse_flag == 1">
              <Action ID="AlwaysSuccess" />
            </Decorator>
            <Action
              ID="ReversePoseStampedVector"
              input_vector="{contour_path_with_overage}"
              output_vector="{contour_path_with_overage}"
            />
          </Control>
          <Decorator
            ID="ForEach"
            index="{contour_index}"
            out="{contour_pose}"
            vector_in="{contour_path_with_overage}"
          >
            <Action
              ID="AddPoseStampedToVector"
              input="{contour_pose}"
              vector="{boustrophedon_path}"
            />
          </Decorator>
          <Action ID="Script" code="reverse_flag := reverse_flag * -1" />
        </Control>
      </Decorator>
      <Action
        ID="VisualizePath"
        marker_lifetime="0.000000"
        marker_name="raster"
        path="{boustrophedon_path}"
        pose_marker_size="0.030000"
        show_poses="false"
      />
      <Action
        ID="BreakpointSubscriber"
        breakpoint_topic="/moveit_pro_breakpoint"
      />
      <Action
        ID="PlanCartesianPath"
        acceleration_scale_factor="1.000000"
        blending_radius="0.005000"
        debug_solution="{debug_solution}"
        ik_cartesian_space_density="0.010000"
        ik_joint_space_density="0.100000"
        joint_trajectory_msg="{joint_trajectory_msg}"
        path="{boustrophedon_path}"
        planning_group_name="manipulator"
        position_only="false"
        tip_offset="0;0;0.1;0;0;0"
        trajectory_sampling_rate="100"
        velocity_scale_factor="1.000000"
      />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtc"
        controller_action_name="/joint_trajectory_controller/follow_joint_trajectory"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Raster Path Along Fuselage">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Training Examples" />
      </MetadataFields>
      <input_port name="bottom_left_position_xyz" default="-1.0;12.0;1.0">
        World-frame XYZ of the bottom-left corner of the raster region on the
        fuselage. Defaults are tuned for the airplane in hangar_sim and the
        manipulator's reach from the "Look at Plane" waypoint.
      </input_port>
      <input_port name="bottom_right_position_xyz" default="1.0;12.0;1.0">
        World-frame XYZ of the bottom-right corner of the raster region.
      </input_port>
      <input_port name="top_right_position_xyz" default="1.0;12.0;1.6">
        World-frame XYZ of the top-right corner of the raster region.
      </input_port>
      <input_port name="top_left_position_xyz" default="-1.0;12.0;1.6">
        World-frame XYZ of the top-left corner of the raster region.
      </input_port>
      <input_port name="slice_edge_number" default="1">
        Which of the four edges of the corner quadrilateral the slice planes run
        along (1-4). Edge 1 is bottom-left to bottom-right.
      </input_port>
      <input_port name="stride_spacing" default="0.1">
        Spacing in meters between adjacent raster strides.
      </input_port>
      <input_port name="overage_distance" default="0.05">
        Length in meters to extend each contour past its start and end before
        stitching, so the tool travels off-surface at row turnarounds.
      </input_port>
      <input_port name="slice_distance_from_plane" default="0.01">
        Tolerance in meters for which cloud points count as "on" each slice
        plane.
      </input_port>
      <input_port name="contour_crop_angle_start" default="0.0">
        Angular start of the contour arc on each slice plane, in
        radians. Combined with `contour_crop_angle_span` to crop the contour to
        the portion of the surface to follow.
      </input_port>
      <input_port name="contour_crop_angle_span" default="-3.0">
        Angular extent of the contour arc on each slice plane, in
        radians. Negative values traverse clockwise; positive values traverse
        counter-clockwise.
      </input_port>
      <input_port name="hull_alpha" default="0.05">
        Alpha-shape parameter controlling how tightly the contour follows the
        cloud edge. Smaller values follow concavities more aggressively; -1
        falls back to a convex hull.
      </input_port>
      <input_port name="max_pose_spacing" default="0.03">
        Maximum spacing in meters between adjacent poses along each contour.
      </input_port>
    </SubTree>
  </TreeNodesModel>
</root>
