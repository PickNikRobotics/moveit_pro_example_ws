<?xml version="1.0" encoding="UTF-8" ?>
<!-- Smoke test: drives the Ridgeback to the docking station (a pose that is free in the nav map)
     with zero parameters. Proves the Semantic Nav drive path end-to-end, independent of the
     resolver/viewpane. NOTE: object *centers* from the semantic map are often inside obstacles
     (walls/shelves); the dock center is in free space, which is why it is used here. -->
<root BTCPP_format="4" main_tree_to_execute="Semantic Navigate to Dock">
  <BehaviorTree
    ID="Semantic Navigate to Dock"
    _description="Smoke test for Semantic Nav: drive to the docking station (free-space pose, map frame)."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="CreatePoseStamped"
        reference_frame="map"
        position_xyz="0.194;28.924;0.0"
        orientation_xyzw="0.0;0.0;0.0;1.0"
        pose_stamped="{target_pose}"
      />
      <Action
        ID="SwitchController"
        activate_controllers="platform_velocity_controller_nav2"
        deactivate_controllers="velocity_force_controller;joint_trajectory_controller;platform_velocity_controller"
      />
      <Action
        ID="NavigateToPoseAction"
        action_name="/navigate_to_pose"
        behavior_tree_path="/opt/ros/humble/share/nav2_bt_navigator/behavior_trees/navigate_to_pose_w_replanning_and_recovery.xml"
        pose_stamped="{target_pose}"
      />
      <Action
        ID="SwitchController"
        activate_controllers="joint_trajectory_controller"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Semantic Navigate to Dock">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Navigation" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
