<?xml version="1.0" encoding="UTF-8" ?>
<!-- Smoke test: drives the Ridgeback to a nav-ready standoff pose (the SE double door, offset
     ~2.25 m into the interior). Validates the standoff approach against the live costmap. If this
     fails, bump the standoff (B owns NAV_STANDOFF_M) or add obstacle-aware per-cluster offsets.
     Stable objective ID so we can iterate the pose without renaming in the UI. -->
<root BTCPP_format="4" main_tree_to_execute="Semantic Navigate (Smoke Test)">
  <BehaviorTree
    ID="Semantic Navigate (Smoke Test)"
    _description="Smoke test for Semantic Nav: drive to the aircraft NOSE approach pose (validates A's riskiest offset)."
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="CreatePoseStamped"
        reference_frame="map"
        position_xyz="0.004;8.573;0.0"
        orientation_xyzw="0.0;0.0;0.7071;0.7071"
        pose_stamped="{target_pose}"
      />
      <Action
        ID="SwitchController"
        activate_controllers="platform_velocity_controller_nav2"
        deactivate_controllers="velocity_force_controller;joint_trajectory_controller;platform_velocity_controller"
      />
      <Action
        ID="NavigateToPoseAction"
        action_name="/navigate_to_pose"
        behavior_tree_path="/opt/ros/humble/share/nav2_bt_navigator/behavior_trees/navigate_to_pose_w_replanning_and_recovery.xml"
        pose_stamped="{target_pose}"
      />
      <Action
        ID="SwitchController"
        activate_controllers="joint_trajectory_controller"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Semantic Navigate (Smoke Test)">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Navigation" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
