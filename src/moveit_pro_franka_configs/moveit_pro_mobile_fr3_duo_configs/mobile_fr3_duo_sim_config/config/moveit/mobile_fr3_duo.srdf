    <disable_collisions link1="left_fr3v2_link3" link2="fr3_duo_mount_origin" reason="Never"/>
    <disable_collisions link1="left_fr3v2_link4" link2="fr3_duo_mount_origin" reason="Never"/>
    <disable_collisions link1="left_fr3v2_link0" link2="fr3_duo_mount_left" reason="Adjacent"/>
    <disable_collisions link1="left_fr3v2_link1" link2="fr3_duo_mount_left" reason="Never"/>
    <disable_collisions link1="left_fr3v2_link2" link2="fr3_duo_mount_left" reason="Never"/>
    <disable_collisions link1="left_fr3v2_link3" link2="fr3_duo_mount_left" reason="Never"/>
    <disable_collisions link1="left_fr3v2_link4" link2="fr3_duo_mount_left" reason="Never"/>
    <disable_collisions link1="right_fr3v2_link0" link2="fr3_duo_mount_mounting_point" reason="Adjacent"/>
    <disable_collisions link1="right_fr3v2_link1" link2="fr3_duo_mount_mounting_point" reason="Never"/>
    <disable_collisions link1="right_fr3v2_link2" link2="fr3_duo_mount_mounting_point" reason="Never"/>
    <disable_collisions link1="right_fr3v2_link3" link2="fr3_duo_mount_mounting_point" reason="Never"/>
    <disable_collisions link1="right_fr3v2_link4" link2="fr3_duo_mount_mounting_point" reason="Never"/>
    <disable_collisions link1="right_fr3v2_link0" link2="fr3_duo_mount_origin" reason="Adjacent"/>
