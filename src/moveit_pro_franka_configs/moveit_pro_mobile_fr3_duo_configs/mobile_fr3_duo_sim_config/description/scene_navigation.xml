<?xml version="1.0" encoding="utf-8" ?>
<mujoco model="scene">
  <include file="robot_navigation.xml" />
  <compiler angle="radian" />
  <option
        timestep="0.005"
        integrator="implicitfast"
        solver="Newton"
        noslip_iterations="2"
        cone="elliptic"
        gravity="0 0 -9.81"
    />

  <size nuser_cam="1" />

  <default>
    <default class="freejoint_collision">
      <geom
                type="mesh"
                group="3"
                mass="0"
                density="0"
                solref="0.005 1"
                solimp="0.9 0.95 0.001 0.5 2"
            />
    </default>
  </default>

  <statistic center="0.3 0 0.4" extent="1" />

  <visual>
    <global azimuth="120" elevation="-20" offwidth="640" offheight="480" />
    <quality shadowsize="2048" />
    <headlight
            diffuse="0.35 0.35 0.35"
            ambient="0.22 0.22 0.22"
            specular="0.05 0.05 0.05"
        />
    <rgba haze="0.08 0.12 0.16 1" />
  </visual>

  <asset>
    <texture
            type="skybox"
            builtin="gradient"
            rgb1=".3 .5 .7"
            rgb2="0 0 0"
            width="512"
            height="512"
        />
    <texture
            name="grid"
            type="2d"
            builtin="checker"
            width="512"
            height="512"
            rgb1="0.45 0.45 0.45"
            rgb2="0.55 0.55 0.55"
        />
    <material
            name="grid"
            texture="grid"
            texrepeat="5 5"
            texuniform="true"
            reflectance=".2"
        />

    <!-- <material
            name="metal_rack"
            rgba="0.75 0.75 0.75 1"
            specular="0.9"
            shininess="0.8"
