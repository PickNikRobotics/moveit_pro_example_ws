            shininess="0.9"
            reflectance="0.4"
        /> -->
    <!-- <material name="handle_light_green" rgba="0.72 0.95 0.58 1" /> -->
    <material
            name="datacenter_wall"
            rgba="1 1 1 1"
            specular="0.15"
            shininess="0.2"
            reflectance="0.05"
        />
  </asset>

  <worldbody>

    <!-- FILL -->
    <light
            name="fill_light"
            pos="-1.6 1.2 2.2"
            dir="0.6 -0.4 -0.7"
            directional="true"
            diffuse="0.35 0.40 0.48"
            specular="0.08 0.08 0.1"
            castshadow="false"
        />

    <!-- RIM -->
    <light
            name="rim_light"
            pos="0 2.4 2.4"
            dir="0 -1 -0.7"
            directional="true"
            diffuse="0.35 0.35 0.4"
            specular="0.2 0.2 0.25"
            castshadow="false"
        />

    <!-- SOFT TOP -->
    <light
            name="top_soft"
            pos="0 0 3.5"
            dir="0 0 -1"
            directional="true"
            diffuse="0.25 0.25 0.25"
            specular="0.05 0.05 0.05"
            castshadow="false"
        />

    <geom
            name="floor"
            type="plane"
            size="10 10 0.1"
            material="grid"
            condim="4"
            contype="4"
            conaffinity="2"
            friction="5 0.005 0.0001"
        />
    <geom
            name="wall_north"
            type="box"
            size="10 0.025 1.25"
            pos="0 10 1.25"
            material="datacenter_wall"
            contype="1"
            conaffinity="1"
        />
    <geom
            name="wall_south"
            type="box"
            size="10 0.025 1.25"
            pos="0 -10 1.25"
            material="datacenter_wall"
            contype="1"
            conaffinity="1"
        />
    <geom
            name="wall_east"
            type="box"
            size="0.025 9.975 1.25"
            pos="10 0 1.25"
            material="datacenter_wall"
            contype="1"
            conaffinity="1"
        />
    <geom
            name="wall_west"
            type="box"
            size="0.025 9.975 1.25"
            pos="-10 0 1.25"
            material="datacenter_wall"
            contype="1"
            conaffinity="1"
        />

