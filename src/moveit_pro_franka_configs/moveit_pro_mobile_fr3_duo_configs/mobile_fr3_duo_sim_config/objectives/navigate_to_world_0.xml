<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Navigate to World 0">
  <BehaviorTree
    ID="Navigate to World 0"
    _description="Navigate the mobile base to the world zero position"
    _favorite="false"
  >
    <!--platform_velocity_controller_nav2 is active at startup, so no controller
         swap is needed here. TODO: once a teleop / whole-body controller is added,
         restore SwitchController calls to swap it with platform_velocity_controller_nav2
         around the navigation block (both claim the wheel command interfaces).-->
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="CreateStampedPose"
        reference_frame="base_link"
        stamped_pose="{start}"
        orientation_xyzw="0.000000;0.000000;0.000000;1.000000"
        position_xyz="0.000000;0.000000;0.000000"
      />
      <Action
        ID="CreateStampedPose"
        reference_frame="world"
        stamped_pose="{goal}"
        orientation_xyzw="0.000000;0.000000;0.000000;1.000000"
        position_xyz="0.000000;0.000000;0.000000"
      />
      <Action
        ID="ComputePathToPoseAction"
        action_name="/compute_path_to_pose"
        goal="{goal}"
        ignore_stamp_time="true"
        path="{path}"
        planning_time="{planning_time}"
        start="{start}"
        timeout_sec="-1.000000"
        use_start="false"
        planner_id="GridBased"
      />
      <Action ID="WaitForUserPathApproval" path="{path}" />
      <Action
        ID="FollowPathAction"
        action_name="/follow_path"
        controller_id="FollowPath"
        distance_to_goal="{distance_to_goal}"
        goal_checker_id="general_goal_checker"
        path="{path}"
        speed="{speed}"
        timeout_sec="-1.000000"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Navigate to World 0">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Navigation" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
