<?xml version="1.0" encoding="UTF-8" ?>
<root
  BTCPP_format="4"
  main_tree_to_execute="Place PoseStamped at other PoseStamped Location"
>
  <!--//////////-->
  <BehaviorTree
    ID="Place PoseStamped at other PoseStamped Location"
    _description=""
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="UnpackPoseStampedMessage"
        pose_stamped="{other_posestamped}"
        pose="{other_pose}"
      />
      <Action
        ID="UnpackPoseStampedMessage"
        pose_stamped="{posestamped_to_place}"
        pose="{pose_to_place}"
      />
      <Action
        ID="UnpackPoseMessage"
        pose="{other_pose}"
        position="{other_position}"
        orientation="{other_orientation}"
      />
      <Action
        ID="UnpackPoseMessage"
        pose="{pose_to_place}"
        position="{position_to_place}"
        orientation="{orientation_to_place}"
      />
      <Action
        ID="CreatePoseMessage"
        position="{other_position}"
        orientation="{orientation_to_place}"
      />
      <Action
        ID="CreatePoseStampedMessage"
        pose_stamped="{resulting_posestamped}"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Place PoseStamped at other PoseStamped Location">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Application Subtrees" />
      </MetadataFields>
      <inout_port
        name="other_posestamped"
        default="{other_posestamped}"
        type="geometry_msgs::msg::PoseStamped"
      />
      <inout_port
        name="posestamped_to_place"
        default="{posestamped_to_place}"
        type="geometry_msgs::msg::PoseStamped"
      />
      <inout_port
        name="resulting_posestamped"
        default="{resulting_posestamped}"
        type="geometry_msgs::msg::PoseStamped"
      />
    </SubTree>
  </TreeNodesModel>
</root>
