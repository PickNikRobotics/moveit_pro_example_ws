<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Send Clicked Point to Nav2">
  <BehaviorTree
    ID="Send Clicked Point to Nav2"
    _description="Prompt the user to click a point on the costmap and send it to Nav2 as a NavigateToPose action goal"
    _favorite="false"
  >
    <Control ID="Sequence" name="root">
      <Action
        ID="GetPoseFromUser"
        is_normal="true"
        pose_prompt="Click a point on the costmap"
        user_pose="{goal_pose}"
        view_name="Visualization"
      />
      <Action
        ID="NavigateToPoseAction"
        action_name="/navigate_to_pose"
        pose_stamped="{goal_pose}"
        timeout_sec="-1.000000"
        distance_remaining="{distance_remaining}"
        estimated_time_remaining="{estimated_time_remaining}"
        navigation_time="{navigation_time}"
        current_pose="{current_pose}"
        ignore_stamp_time="true"
        number_of_recoveries="{number_of_recoveries}"
        behavior_tree_path="/opt/ros/humble/share/nav2_bt_navigator/behavior_trees/navigate_to_pose_w_replanning_and_recovery.xml"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Send Clicked Point to Nav2">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Navigation" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
