<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Navigate To Server Rack Subtree">
  <BehaviorTree
    ID="Navigate To Server Rack Subtree"
    _description="Navigates to given pose"
    _favorite="false"
  >
    <Control ID="Sequence" name="root">
      <Action
        ID="NavigateToPoseAction"
        action_name="/navigate_to_pose"
        pose_stamped="{goal_pose}"
        timeout_sec="-1.000000"
        distance_remaining="{distance_remaining}"
        estimated_time_remaining="{estimated_time_remaining}"
        navigation_time="{navigation_time}"
        current_pose="{current_pose}"
        ignore_stamp_time="true"
        number_of_recoveries="{number_of_recoveries}"
        behavior_tree_path="/opt/ros/jazzy/share/nav2_bt_navigator/behavior_trees/navigate_to_pose_w_replanning_and_recovery.xml"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Navigate To Server Rack Subtree">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Application Subtrees" />
      </MetadataFields>
      <inout_port
        name="goal_pose"
        default="{goal_pose}"
        type="geometry_msgs::msg::PoseStamped"
      />
    </SubTree>
  </TreeNodesModel>
</root>
