<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Velocity Force Controller Zero">
  <!--//////////-->
  <BehaviorTree
    ID="Velocity Force Controller Zero"
    _description="Publish a zero force command to the Velocity Force Controller"
    _favorite="true"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="CreateTwistStamped"
        twist_stamped="{desired_twist}"
        angular_velocity_xyz="0.0;0.0;0.0"
        linear_velocity_xyz="0.0;0.0;0.0"
      />
      <Action
        ID="UnpackTwistStampedMessage"
        name="UnpackTwistStampedMessage"
        twist="{twist}"
        header="{header}"
        twist_stamped="{desired_twist}"
      />
      <Action
        ID="SwitchController"
        activate_controllers="velocity_force_controller"
      />
      <Action
        ID="CreateWrenchStamped"
        torque_xyz="0.0;0.0;0.0"
        force_xyz="0.0;0.0;0.0"
        wrench_stamped="{desired_wrench}"
      />
      <Action
        ID="UnpackWrenchStampedMessage"
        name="UnpackWrenchStampedMessage"
        wrench="{wrench}"
        header="{header}"
        wrench_stamped="{desired_wrench}"
      />
      <Decorator ID="KeepRunningUntilFailure">
        <Action
          ID="PublishVelocityForceCommand"
          wrench_gain="0.1"
          velocity_controlled_axes="0;0;0;0;0;0"
          force_controlled_axes="1;1;1;0;0;0"
          twist="{twist}"
          wrench="{wrench}"
        />
      </Decorator>
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Velocity Force Controller Zero">
      <MetadataFields>
        <Metadata subcategory="Application - Basic Examples" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
