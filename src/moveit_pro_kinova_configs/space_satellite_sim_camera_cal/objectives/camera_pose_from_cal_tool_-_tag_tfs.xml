<?xml version="1.0" encoding="UTF-8" ?>
<root
  BTCPP_format="4"
  main_tree_to_execute="Camera Pose from Cal Tool - Tag TFs"
>
  <!--//////////-->
  <BehaviorTree
    ID="Camera Pose from Cal Tool - Tag TFs"
    computed_pose="{computed_pose}"
    _description="Use (externally) published TF frames of the calibration tool's AprilTags to compute the camera pose."
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action ID="ResetPoseStampedVector" vector="{pose_stamped_vector}" />
      <SubTree
        ID="Add Pose from TF Frame to Vector"
        _collapsed="true"
        pose_frame="satellite_tag_1"
        reference_frame="{camera_optical_frame}"
        vector="{pose_stamped_vector}"
        name="Right AprilTag"
      />
      <SubTree
        ID="Add Pose from TF Frame to Vector"
        _collapsed="true"
        pose_frame="satellite_tag_0"
        reference_frame="{camera_optical_frame}"
        vector="{pose_stamped_vector}"
        name="Left AprilTag"
      />
      <SubTree
        ID="Add Pose from TF Frame to Vector"
        _collapsed="true"
        pose_frame="satellite_tag_2"
        reference_frame="{camera_optical_frame}"
        vector="{pose_stamped_vector}"
        name="Bottom AprilTag"
      />
      <Decorator
        ID="ForEach"
        index="{index}"
        out="{out_tag_pose}"
        vector_in="{pose_stamped_vector}"
      >
        <Control ID="Sequence">
          <Action ID="Script" code="name := index+100" />
          <Action
            ID="VisualizePose"
            marker_lifetime="0.000000"
            marker_size="0.100000"
            pose="{out_tag_pose}"
            marker_name="{name}"
          />
        </Control>
      </Decorator>
      <Action
        ID="CalibrateCameraPose"
        base_link="base_link"
        calibration_tool_frame="calibration_tool_frame"
        computed_pose="{computed_pose}"
        debug_base_calibration_pose="{base_to_calib_pose}"
        debug_camera_calibration_pose="{camera_to_calib_pose}"
        detected_poses="{pose_stamped_vector}"
        camera_optical_frame="{camera_optical_frame}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.0"
        marker_size="0.100000"
        pose="{camera_to_calib_pose}"
        name=""
        marker_name="AprilTag center pose"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.0"
        marker_size="0.100000"
        pose="{base_to_calib_pose}"
        name=""
        marker_name="Current Calibration Tool Pose"
      />
      <Action
        ID="VisualizePose"
        marker_name="Single-Image Optical Pose"
        marker_size="0.100000"
        pose="{computed_pose}"
        name=""
        marker_lifetime="0.0"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Camera Pose from Cal Tool - Tag TFs">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Perception - Camera Calibration" />
      </MetadataFields>
      <inout_port
        name="camera_optical_frame"
        default="{camera_optical_frame}"
      />
      <output_port name="computed_pose" default="{computed_pose}" />
    </SubTree>
  </TreeNodesModel>
</root>
