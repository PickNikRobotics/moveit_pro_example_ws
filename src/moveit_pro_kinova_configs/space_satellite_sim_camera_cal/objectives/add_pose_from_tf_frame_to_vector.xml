<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Add Pose from TF Frame to Vector">
  <!--//////////-->
  <BehaviorTree
    ID="Add Pose from TF Frame to Vector"
    vector="{pose_stamped_vector}"
    _description="Creates a stamped pose from a published TF frame in the desired reference frame, and adds it to a vector."
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="CreateStampedPose"
        reference_frame="{pose_frame}"
        stamped_pose="{stamped_pose}"
      />
      <Action
        ID="TransformPoseFrame"
        input_pose="{stamped_pose}"
        output_pose="{stamped_pose}"
        target_frame_id="{reference_frame}"
      />
      <Action
        ID="AddPoseStampedToVector"
        input="{stamped_pose}"
        vector="{vector}"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Add Pose from TF Frame to Vector">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Perception - Camera Calibration" />
      </MetadataFields>
      <inout_port name="pose_frame" default="{pose_frame_name}" />
      <inout_port name="reference_frame" default="{reference_frame_name}" />
      <inout_port name="vector" default="{pose_stamped_vector}" />
    </SubTree>
  </TreeNodesModel>
</root>
