<?xml version="1.0" encoding="UTF-8" ?>
<root
  BTCPP_format="4"
  main_tree_to_execute="Camera Pose from Cal Tool - Detect Tags"
>
  <!--//////////-->
  <BehaviorTree
    ID="Camera Pose from Cal Tool - Detect Tags"
    computed_pose="{computed_pose}"
    _description="Compute the camera optical pose from the calibration tool's AprilTags with a single joint PnP solve over every tag corner."
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="GetImage"
        message_out="{image}"
        message_timeout_sec="2.0"
        topic_name="{camera_image_topic}"
      />
      <Action
        ID="GetCameraInfo"
        message_out="{camera_info}"
        message_timeout_sec="2.0"
        topic_name="{camera_info_topic}"
      />
      <Action
        ID="CalibrateCameraPosePnp"
        image="{image}"
        camera_info="{camera_info}"
        base_link="base_link"
        tag_frame_prefix="{tag_frame_prefix}"
        tag_size="0.051"
        tag_family="tag36h11"
        min_tags="3"
        computed_pose="{computed_pose}"
      />
      <Action
        ID="VisualizePose"
        marker_name="Single-Image Optical Pose"
        marker_size="0.1"
        pose="{computed_pose}"
        name=""
        marker_lifetime="0.0"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Camera Pose from Cal Tool - Detect Tags">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Perception - Camera Calibration" />
      </MetadataFields>
      <inout_port name="camera_image_topic" default="{camera_image_topic}" />
      <inout_port name="camera_info_topic" default="{camera_info_topic}" />
      <inout_port
        name="camera_optical_frame"
        default="{camera_optical_frame}"
      />
      <inout_port name="tag_frame_prefix" default="calibration_tag_" />
      <inout_port name="computed_pose" default="{computed_pose}" />
    </SubTree>
  </TreeNodesModel>
</root>
