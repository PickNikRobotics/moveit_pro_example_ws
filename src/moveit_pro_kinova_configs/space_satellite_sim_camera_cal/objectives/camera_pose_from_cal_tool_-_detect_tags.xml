<?xml version="1.0" encoding="UTF-8" ?>
<root
  BTCPP_format="4"
  main_tree_to_execute="Camera Pose from Cal Tool - Detect Tags"
>
  <!--//////////-->
  <BehaviorTree
    ID="Camera Pose from Cal Tool - Detect Tags"
    computed_pose="{computed_pose}"
    parameters="{parameters}"
    _description="Directly detect the calibration tool's AprilTags to compute the camera pose."
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="GetImage"
        message_out="{image}"
        timeout_sec="2.0"
        topic_name="/servicer_camera/color"
      />
      <Action
        ID="GetCameraInfo"
        message_out="{camera_info}"
        timeout_sec="2.0"
        topic_name="/servicer_camera/camera_info"
      />
      <Action
        ID="DetectAprilTags"
        camera_info="{camera_info}"
        detections="{detections}"
        image="{image}"
        parameters="{parameters}"
      />
      <Action ID="ResetPoseStampedVector" vector="{pose_stamped_vector}" />
      <SubTree
        ID="Add AprilTag Pose To Vector"
        _collapsed="true"
        detections="{detections}"
        name="topRight"
        target_id="0"
        pose_vector_to_append="{pose_stamped_vector}"
      />
      <SubTree
        ID="Add AprilTag Pose To Vector"
        _collapsed="true"
        detections="{detections}"
        target_id="5"
        name="topLeft"
        pose_vector_to_append="{pose_stamped_vector}"
      />
      <SubTree
        ID="Add AprilTag Pose To Vector"
        _collapsed="true"
        detections="{detections}"
        target_id="3"
        name="bottom"
        pose_vector_to_append="{pose_stamped_vector}"
      />
      <Decorator
        ID="ForEach"
        index="{index}"
        out="{out_tag_pose}"
        vector_in="{pose_stamped_vector}"
      >
        <Control ID="Sequence">
          <Action ID="Script" code="name := index+100" />
          <Action
            ID="VisualizePose"
            marker_lifetime="0.000000"
            marker_size="0.100000"
            pose="{out_tag_pose}"
            marker_name="{name}"
          />
        </Control>
      </Decorator>
      <Action
        ID="CalibrateCameraPose"
        base_link="base_link"
        calibration_tool_frame="calibration_tool_frame"
        computed_pose="{computed_pose}"
        debug_base_calibration_pose="{base_to_calib_pose}"
        debug_camera_calibration_pose="{camera_to_calib_pose}"
        detected_poses="{pose_stamped_vector}"
        camera_optical_frame="{camera_optical_frame}"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.0"
        marker_size="0.100000"
        pose="{camera_to_calib_pose}"
        name=""
        marker_name="AprilTag center pose"
      />
      <Action
        ID="VisualizePose"
        marker_lifetime="0.0"
        marker_size="0.100000"
        pose="{base_to_calib_pose}"
        name=""
        marker_name="Current Calibration Tool Pose"
      />
      <Action
        ID="VisualizePose"
        marker_name="Single-Image Optical Pose"
        marker_size="0.100000"
        pose="{computed_pose}"
        name=""
        marker_lifetime="0.0"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Camera Pose from Cal Tool - Detect Tags">
      <MetadataFields>
        <Metadata runnable="false" />
        <Metadata subcategory="Perception - Camera Calibration" />
      </MetadataFields>

      <inout_port
        name="camera_optical_frame"
        default="{camera_optical_frame}"
      />
      <output_port name="computed_pose" default="{computed_pose}" />
      <input_port name="parameters" default="{parameters}" />
    </SubTree>
  </TreeNodesModel>
</root>
