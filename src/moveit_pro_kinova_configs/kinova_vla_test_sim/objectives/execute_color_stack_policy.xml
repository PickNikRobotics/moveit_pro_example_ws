<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Execute Color-Stack Policy">
  <BehaviorTree
    ID="Execute Color-Stack Policy"
    _description="Run a trained policy via ExecutePolicy to stack one cube on another."
    _favorite="true"
  >
    <Control ID="Sequence" name="root">
      <Action
        ID="SwitchController"
        activate_controllers="joint_trajectory_admittance_controller"
        deactivate_controllers="velocity_force_controller"
        strictness="1"
        timeout="-1.000000"
        controller_list_action_name="/controller_manager/list_controllers"
        controller_switch_action_name="/controller_manager/switch_controller"
      />
      <Action
        ID="ExecutePolicy"
        name="ExecutePolicy"
        policy_service_name="/get_action_chunk"
        joint_group_name="manipulator"
        prompt="stack the blue cube on the green cube"
        total_action_steps="1200"
        dt="0.1"
        committed_action_steps="12"
        num_interpolation_points="200"
        goal_path_tolerance="99.0"
        policy_tracking_weight="300.0"
        policy_uses_real_time_chunking="true"
        policy_call_timeout="10.0"
        image_topics="/scene_camera/color;/wrist_camera/color;/overview_camera/color"
        image_names="front;wrist;overview"
        joint_states_topic="/joint_states"
        absolute_force_torque_threshold="250;250;250;80;80;80"
        gripper_command_action_name="/robotiq_gripper_controller/gripper_cmd"
        gripper_joint_name="robotiq_85_left_knuckle_joint"
        guidance_horizon="8"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Execute Color-Stack Policy">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Color-Cube Stacking" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
